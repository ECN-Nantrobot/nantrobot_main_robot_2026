<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="MainTree">
  <BehaviorTree ID="InitSequence">
    <Sequence>
      <Script code="wait:=true"/>
      <Repeat num_cycles="-1"
              _while="wait">
        <Sequence>
          <GpioRead pin="17"
                    value="{@team}"
                    _description="Set the team"/>
          <GpioWrite pin="18"
                     state="{@team}"/>
          <GpioRead pin="27"
                    value="{wait}"/>
        </Sequence>
      </Repeat>
      <SetTeam team="{@team}"/>
      <InitOdom/>
      <Script code="wait:=true"/>
      <Repeat num_cycles="-1"
              _while="wait">
        <GpioRead pin="22"
                  value="{wait}"/>
      </Repeat>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="MainTree">
    <Sequence>
      <SubTree ID="InitSequence"
               _autoremap="false"/>
      <Timeout msec="10000">
        <Fallback _description="Stop everything if there is no more time left">
          <Timeout msec="8500">
            <Goto x="12"
                  y="27"
                  forward="true"
                  current_x="{@current_x}"
                  current_y="{@current_y}"
                  current_theta="{@current_theta}"/>
          </Timeout>
          <Goto x="0.3"
                y="-2.7"
                forward="true"
                current_x="{@current_x}"
                current_y="{@current_y}"
                current_theta="{@current_theta}"/>
        </Fallback>
      </Timeout>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="Goto"
            editable="true">
      <input_port name="x"
                  type="double">X coordinates</input_port>
      <input_port name="y"
                  type="double">Y coordinates</input_port>
      <input_port name="forward"
                  default="true"
                  type="bool">Forward travel direction (true=forward, false=reverse)</input_port>
      <output_port name="current_x"
                   type="double"/>
      <output_port name="current_y"
                   type="double"/>
      <output_port name="current_theta"
                   type="double"/>
    </Action>
    <Action ID="GpioRead"
            editable="true">
      <input_port name="pin"
                  type="unsigned int"/>
      <output_port name="value"
                   type="bool"/>
    </Action>
    <Action ID="GpioWrite"
            editable="true">
      <input_port name="pin"
                  type="unsigned int"/>
      <input_port name="state"
                  type="bool"/>
    </Action>
    <Action ID="InitOdom"
            editable="true"/>
    <Action ID="SetTeam"
            editable="true">
      <input_port name="team"
                  default="{@team}"
                  type="bool"/>
    </Action>
  </TreeNodesModel>

</root>
