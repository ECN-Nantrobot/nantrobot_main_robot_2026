<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="MainTree">
    <Sequence>
      <RetryUntilSuccessful num_attempts="-1">
        <Sequence>
          <SetTeam/>
          <GpioRead pin="17"/>
        </Sequence>
      </RetryUntilSuccessful>
      <InitPoses/>
      <Fallback _description="Stop everything if there is no more time left">
        <Timeout msec="100">
          <Fallback _description="Always try to go back to the ending zone if there is no more time">
            <Timeout msec="85">
              <Sequence name="root_sequence">
                <MoveTo/>
                <Pick/>
              </Sequence>
            </Timeout>
            <MoveTo/>
          </Fallback>
        </Timeout>
        <Stop/>
      </Fallback>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="GpioRead"
            editable="true">
      <input_port name="pin"
                  type="unsigned int"/>
    </Action>
    <Action ID="InitPoses"
            editable="true"/>
    <Action ID="MoveTo"
            editable="true"/>
    <Action ID="Pick"
            editable="true"/>
    <Action ID="SetTeam"
            editable="true"/>
    <Action ID="Stop"
            editable="true"/>
  </TreeNodesModel>

</root>

